# Environment Variables for ThinkyLM
# Copy this file to .env and fill in your values
# Never commit .env to version control

# Model checkpoint path (optional)
# THINKYLM_CHECKPOINT=checkpoints/debug_1m/latest

# API settings
API_HOST=127.0.0.1
API_PORT=8000

# Performance (safe CPU defaults)
TOKENIZERS_PARALLELISM=false
OMP_NUM_THREADS=2
MKL_NUM_THREADS=2

# TensorBoard
TENSORBOARD_LOG_DIR=runs/

# HuggingFace (if needed for tokenizer upload only)
# HF_TOKEN=your_token_here
